{{- /* Nix rejects path: inputs whose ancestor directories are symlinks
       (e.g. ~/code -> /some/other/dir). Canonicalize once so all
       path: URLs below are symlink-free. */ -}}
{{- $sourceDir := output "realpath" .chezmoi.sourceDir | trim -}}
{
  inputs = {
    persist = {
      url = "github:christian-oudard/persist";
      flake = false;
    };
    claude-plugins-official = {
      url = "github:anthropics/claude-plugins-official";
      flake = false;
    };
    # Each subtree below gets copied into the nix store and exposed to the
    # cave. Keep these scoped to dotfiles directories that don't contain
    # secrets. the rest of the dotfiles tree (age-encrypted files, .keys/,
    # etc.) stays out of the cave.
    cave-modules = {
      url = "path:{{ $sourceDir }}/nixos-config/modules";
      flake = false;
    };
    nvim-config = {
      url = "path:{{ $sourceDir }}/dot_config/nvim";
      flake = false;
    };
    zsh-config = {
      url = "path:{{ $sourceDir }}/dot_config/zsh";
      flake = false;
    };
    claude-md = {
      url = "path:{{ env "HOME" }}/.claude/CLAUDE.md";
      flake = false;
    };
    git-ignore = {
      url = "path:{{ $sourceDir }}/dot_config/git/ignore";
      flake = false;
    };
  };

  config =
    {
      pkgs,
      persist,
      claude-plugins-official,
      cave-modules,
      nvim-config,
      zsh-config,
      claude-md,
      git-ignore,
      ...
    }:
    let
      claude = import "${cave-modules}/claude.nix" {
        inherit persist claude-plugins-official;
      };
      # cav-host (on the cave PATH) writes BEL to the supervisor's terminal;
      # $PPID would point at whatever transient process triggered the bell,
      # so the host-side command is not usable here.
      bellCmd = "cav-host bell";
    in
    {
      imports = [
        "${cave-modules}/neovim.nix"
        "${cave-modules}/zsh.nix"
      ];

      _module.args.zsh-config = zsh-config;

      # claude.nix exposes plugin paths, lsp servers, and settings as plain
      # data; wire them through coding-cave's deep-merge layer so cave-system
      # defaults (model, statusline, marketplace, ...) compose cleanly.
      coding-cave.claude-code = {
        plugins = claude.pluginsFor pkgs;
        extraSettings = claude.settings;
        # The cave module owns programs.claude-code.skills, so contribute
        # ours through a bundle rather than setting that option directly.
        bundles = [ { src = claude.skillsSrc; } ];
        hooks = claude.bellHooks bellCmd;
      };
      programs.claude-code.lspServers = claude.lspServers;
      programs.claude-code.context = builtins.readFile claude-md;

      programs.git.ignores = pkgs.lib.splitString "\n" (builtins.readFile git-ignore);

      # rust-analyzer resolves std/core/alloc from the stdlib source, which
      # nixpkgs rustc's sysroot omits. cav injects home.sessionVariables into
      # the agent namespace (env.json -> bwrap --setenv), so the LSP server
      # picks this up without relying on shell sourcing.
      home.sessionVariables.RUST_SRC_PATH = "${pkgs.rustPlatform.rustLibSrc}";

      # General build toolchains live in each project's dev shell, not here.
      # The exception is the LSP toolchains at the end of this list: the
      # agent's LSP tool launches language servers (and the toolchains they
      # shell out to) from the base cave shell, which has no direnv, so they
      # must be on the base PATH.
      home.packages = with pkgs; [
        which
        tree
        eza
        nano
        direnv
        nix-direnv
        zsh

        # Terminal utilities (parity with host home.nix, minus network and
        # GUI tools). fd, file, and diff are also referenced in claude.nix's
        # permission allow-list, so they must be on PATH.
        diffutils
        dust
        fd
        file
        fzf
        htop
        unzip

        # LSP servers + their toolchains (consumed by
        # programs.claude-code.lspServers above).
        rust-analyzer cargo rustc rustfmt clippy
        gopls go
        pyright python3
      ];

      # neovim.nix supplies programs.neovim and writes hm-generated.lua
      # under nvim/lua/. recursive=true makes ~/.config/nvim a real
      # directory of symlinks rather than a single symlink to the store
      # path, leaving room for hm-generated.lua to be written alongside.
      xdg.configFile."nvim" = {
        source = nvim-config;
        recursive = true;
      };

      home.file.".config/direnv/direnvrc".text =
        "source ${pkgs.nix-direnv}/share/nix-direnv/direnvrc";

      # Override coding-cave's default statusline (mkDefault) to compose the
      # model class and context% (from Claude Code's JSON) onto the byline
      # and persist segments. executable stays true from cave-system.
      home.file.".claude/statusline.sh".source = cave-modules + "/statusline.sh";
    };
}
