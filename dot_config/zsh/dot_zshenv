# Environment variables.
export \
    NIX_BUILD_SHELL=zsh \
    EDITOR=nvim \
    SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket" \
    GPG_TTY=$(tty 2>/dev/null) \
    VIRTUAL_ENV_DISABLE_PROMPT=1 \
    AUTOENV_ENABLE_LEAVE=1 \
    FZF_DEFAULT_COMMAND='fd --type f --hidden' \
    PNPM_HOME=$HOME/.local/bin \
    GRIM_DEFAULT_DIR=$HOME/screenshots \
    LIBVIRT_DEFAULT_URI=qemu:///system \
    MODAL_CONFIG_PATH="$HOME/.config/modal/modal.toml" \
    ENABLE_LSP_TOOL=1 \
    GOBIN=$HOME/.local/bin \
    GOPATH=$HOME/.local/share/go \
    PDFCONVERT_OUTPUT_DIR="$HOME/files/library/pdfconvert_documents/" \

# Prepend nix-ld libs, preserving any inherited LD_LIBRARY_PATH (direnv, nix-shell).
# typeset -U dedupes so nested zsh doesn't re-prepend on each invocation.
typeset -TUx LD_LIBRARY_PATH ld_library_path
ld_library_path=( ${(s.:.)NIX_LD_LIBRARY_PATH} $ld_library_path )

# Executable search path.
typeset -U path PATH
path=(
    ~/bin
    ~/.local/bin
    ~/.cargo/bin
    ~/.npm-global/bin
    ~/.ghcup/bin
    $path
)
export PATH
